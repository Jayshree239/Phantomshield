{
  "manifest_version": 3,
  "name": "PhantomShield",
  "version": "0.1.0",
  "description": "AI-powered phishing detection, explanation and education",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PhantomShield"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
