# d:/SPECTER/phantomshield/backend/.env.example
# App
APP_NAME=PhantomShield API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# API
API_PREFIX=/api
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","https://phantomshield.vercel.app"]

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Database (Neon PostgreSQL)
# Use either NEON_DATABASE_URL or DATABASE_URL.
NEON_DATABASE_URL=
DATABASE_URL=
DB_CONNECT_TIMEOUT=10

# Redis
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# ML model files
MODEL_PATH=ml/models
RF_MODEL_FILE=random_forest.pkl
XGB_MODEL_FILE=xgboost_model.pkl
SCALER_FILE=scaler.pkl

# Optional phishing intel APIs
PHISHTANK_API_KEY=
VIRUSTOTAL_API_KEY=

# Network timeouts
SSL_CHECK_TIMEOUT=5
WHOIS_TIMEOUT=10
